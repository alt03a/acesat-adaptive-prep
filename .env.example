# Copy this file to .env (or just export the variable in your shell) and
# fill in your own key. The app runs without it — explanations and the
# weekly plan fall back to rule-based text — but AI-generated, tailored
# feedback only kicks in once this is set.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional — defaults to 5000
PORT=5000
